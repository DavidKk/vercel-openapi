{
  "name": "unbnd",
  "version": "0.1.0",
  "private": true,
  "description": "This service collects and caches commonly used public OPENAPIs to facilitate developer access. It provides caching and forwarding services for commonly used public APIs, making it easier for developers to quickly access them.",
  "repository": {
    "type": "git",
    "url": "https://github.com/DavidKk/vercel-openapi"
  },
  "scripts": {
    "commit": "git-cz",
    "ci:coverage": "pnpm test",
    "postinstall": "node --experimental-modules ./scripts/postinstall.mjs",
    "preinstall": "node --experimental-modules ./scripts/preinstall.mjs",
    "generate:module": "ts-node --project .ai/generators/tsconfig.json .ai/generators/cli.ts",
    "validate:ai": "ts-node --project .ai/generators/tsconfig.json .ai/generators/validate.ts",
    "validate:modules-registry": "ts-node --project .ai/generators/tsconfig.json .ai/generators/validateModulesRegistry.ts",
    "format": "prettier --config .prettierrc.js --write \"**/*.{js,jsx,ts,tsx,d.ts,vue,md,json,yml,yaml}\"",
    "lint": "pnpm lint:ts",
    "lint:ts": "eslint -c eslint.config.mjs --fix .",
    "typecheck": "tsc --noEmit",
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "test": "jest -c ./jest.config.ts --coverage --reporters=default --reporters=jest-junit --passWithNoTests",
    "test:watch": "jest --watch",
    "playwright:install": "playwright install",
    "test:e2e": "playwright test --reporter=list",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:auto": "playwright test",
    "ok": "pnpm format && pnpm lint && pnpm typecheck && pnpm test && pnpm test:e2e",
    "dev:e2e": "next dev --hostname 127.0.0.1 --port 3000",
    "export:china-geo": "node ./scripts/export-china-geo-pg-ipv4.mjs",
    "export:china-geo:direct": "bash scripts/export-china-geo-pg.sh",
    "export:china-geo:sql": "bash scripts/export-china-geo-sql.sh",
    "prepare": "husky"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@libsql/client": "^0.14.0",
    "@playwright/test": "^1.56.0",
    "@supabase/supabase-js": "^2.49.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@upstash/redis": "^1.37.0",
    "@vercel/analytics": "^2.0.0",
    "@vercel/speed-insights": "^2.0.0",
    "ahooks": "^3.8.4",
    "classnames": "^2.5.1",
    "cookie": "^1.0.2",
    "date-fns": "^4.1.0",
    "fuzzball": "2.2.3",
    "jose": "^6.2.1",
    "jszip": "^3.10.1",
    "next": "16.1.6",
    "otplib": "^12.0.1",
    "prism-react-renderer": "^2.4.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-icons": "^5.4.0",
    "react-virtuoso": "^4.14.1",
    "yaml": "^2.7.0",
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.3.0",
    "@commitlint/config-conventional": "^19.2.2",
    "@eslint/eslintrc": "^3",
    "@jest/types": "^29.6.3",
    "@playwright/test": "^1.56.1",
    "@types/chalk": "^2.2.0",
    "@types/jest": "^29.5.12",
    "@types/node": "^20",
    "@typescript-eslint/eslint-plugin": "^7.16.1",
    "@typescript-eslint/parser": "^7.16.1",
    "chalk": "^5.3.0",
    "commitizen": "^4.2.4",
    "commitlint-plugin-i18n": "^0.0.1-alpha.3",
    "cz-customizable": "^7.2.1",
    "cz-customizable-i18n-config": "^0.0.1-alpha.2",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-import": "^2.29.0",
    "eslint-plugin-prettier": "^5.2.1",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "jest-junit": "^16.0.0",
    "jest-runner-tsd": "^6.0.0",
    "json5": "^2.2.3",
    "lint-staged": "^15.2.7",
    "postcss": "^8",
    "prettier": "^3.4.2",
    "pretty-error": "^4.0.0",
    "raw-loader": "^4.0.2",
    "rimraf": "^6.0.1",
    "spinnies": "^0.5.1",
    "tailwindcss": "^3.4.1",
    "ts-jest": "^29.2.3",
    "ts-node": "^10.9.2",
    "ts-patch": "^3.2.1",
    "tsd-lite": "^0.9.0",
    "typescript": "^5",
    "typescript-transform-paths": "^3.4.7"
  },
  "packageManager": "pnpm@10.30.2+sha512.36cdc707e7b7940a988c9c1ecf88d084f8514b5c3f085f53a2e244c2921d3b2545bc20dd4ebe1fc245feec463bb298aecea7a63ed1f7680b877dc6379d8d0cb4"
}
