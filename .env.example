# -----------------------------------------------------------------------------
# Auth / JWT / Function Calling (OpenAI)
# -----------------------------------------------------------------------------

# Admin Username
ACCESS_USERNAME=""

# Admin Password
ACCESS_PASSWORD=""

# Optional. If set, login requires 2FA token verified by server-side logic.
ACCESS_2FA_SECRET=""

# JWT signing key for /api/auth/login tokens.
# If unset, the server falls back to ACCESS_PASSWORD or a built-in default.
JWT_SECRET=""

# JWT expiration time for generated tokens (e.g. 1d, 7d).
JWT_EXPIRES_IN="1d"

# OpenAI API key for POST /api/function-calling/chat
OPENAI_API_KEY=""

# Optional. (Legacy) Preferred YAML filename hint for clash rules in older setups.
# This option has no effect when using the KV-based proxy-rule clash cache.
# PROXY_RULE_CLASH_FILE="clash.unbnd.yaml"
# PROXY_RULE_CLASH_FILE="clash.vercel-proxy-rule.yaml"

# Optional. Raw JSON file URL for ZeroOmega backup (merged into public clash config).
# Preferred: `ZERO_OMEGA_GIST_URL` (e.g. https://gist.githubusercontent.com/.../raw/ZeroOmega.json)
# ZERO_OMEGA_GIST_URL=""

# (No legacy alias; use ZERO_OMEGA_GIST_URL)

# Set to 1 to fetch gfwlist while NODE_ENV=development (otherwise skipped in dev).
# PROXY_RULE_FETCH_GFWLIST_IN_DEV="0"

# -----------------------------------------------------------------------------
# China GEO (reverse geocode, /api/geo, weather location)
# -----------------------------------------------------------------------------

# Supabase project for china_geo. Run sql/init-china-geo.sql once to create table + RPC; see sql/README.md.
CHINA_GEO_SUPABASE_URL=""
CHINA_GEO_SUPABASE_ANON_KEY=""
# Optional: service role key if RLS blocks anon read on china_geo.
# CHINA_GEO_SUPABASE_SERVICE_ROLE_KEY=""

# Turso (geo server cache L2 on Edge). Optional; when set, geo cache falls back to Turso after memory.
# Create DB at https://turso.tech ; then: Database URL and Auth Token.
# TURSO_DATABASE_URL="libsql://your-db-your-org.turso.io"
# TURSO_AUTH_TOKEN=""

# -----------------------------------------------------------------------------
# Weather (和风天气 QWeather)
# -----------------------------------------------------------------------------

# QWeather API Key (real-time + hourly forecast). https://dev.qweather.com
QWEATHER_API_KEY=""

# -----------------------------------------------------------------------------
# Exchange rate
# -----------------------------------------------------------------------------
# Optional: FreeCurrencyAPI.com API key (https://freecurrencyapi.com). When set, requests use it and avoid IP-based limits; when unset, fallback to ExchangeRate-API.com (no key, may be rate-limited by IP).
# FREECURRENCYAPI_API_KEY=""

# -----------------------------------------------------------------------------
# Movies (cron: 猫眼 Maoyan + TMDB merge → KV)
# -----------------------------------------------------------------------------
# 猫眼 (Maoyan): no API key; uses public apis.netstart.cn/maoyan (topRated, mostExpected).
# TMDB: requires TMDB_API_KEY for popular/upcoming and enrichment.

# --- TMDB (themoviedb.org) ---
TMDB_API_KEY=""
# Optional. Default zh-CN.
TMDB_LANGUAGE="zh-CN"
# Optional region filter, e.g. CN, US.
TMDB_REGION=""

# -----------------------------------------------------------------------------
# TASI (Saudi daily: cf-feed-bridge + Turso)
# -----------------------------------------------------------------------------
# Base URL of TASI feed for today's data. Required for /api/finance/tasi/* (today) and cron sync tasi-sync.
# Feed must expose: GET {url}/api/finance/tasi/company/daily → TasiCompanyDailyRecord[]
#                   GET {url}/api/finance/tasi/summary/daily → TasiMarketSummary
# TASI_FEED_URL="https://feed.davidjones.fun"

# -----------------------------------------------------------------------------
# Debug (local only)
# -----------------------------------------------------------------------------

# Default: OFF — leave unset so caching works normally. Only for local debugging: set to 1, true, or yes in .env.local
# to disable app caches (e.g. news pool memory + KV) and force Cache-Control: private, no-store on standard JSON.
# Never set in production unless you fully intend to (hurts performance and load).
# DISABLE_CACHE="1"

# -----------------------------------------------------------------------------
# News (RSS aggregation via RSSHub-compatible base URL)
# -----------------------------------------------------------------------------

# Optional. Base URL of your RSSHub instance (no trailing path). Feeds are requested as {base}{rsshubPath} per services/news/config/news-sources.manifest.ts.
# RSSHUB_BASE_URL="https://rsshub.app"

# Optional. Extra HTTP headers (JSON object) sent on every News RSS upstream fetch — e.g. reverse proxy auth, API gateway, or Cloudflare Access:
# RSSHUB_REQUEST_HEADERS_JSON='{"CF-Access-Client-Id":"<id>","CF-Access-Client-Secret":"<secret>"}'
# Only top-level string values are used; invalid JSON is ignored (check server logs).
# RSSHUB_REQUEST_HEADERS_JSON=""

# Optional. Per-feed timeout (ms) for News aggregation. Default 30000. Slow routes (e.g. weibo) often exceed 12s when RSSHub is busy.
# NEWS_RSS_FETCH_TIMEOUT_MS="30000"

# Optional. Max concurrent RSS fetches (clamped 1–16). Default 8. Lower (e.g. 1) if RSSHub or a reverse proxy returns 503 under burst.
# NEWS_RSS_FETCH_CONCURRENCY="8"

# Optional. Retries per feed for HTTP 429/502/503/504 (exponential backoff + jitter). Default 3 attempts. Set to 1 to disable retries.
# NEWS_RSS_FETCH_MAX_ATTEMPTS="3"

# Optional. Hard HTTP budget (ms) for `GET /api/news/feed`: the handler aims to finish the **pool phase** by `deadline − tail` so the full JSON response returns before Vercel’s ~10s Hobby limit. Default 10000 (clamped 5000–30000). Effective merge wall is min(`NEWS_FEED_MERGE_WALL_MS`, that remaining budget). Response header `X-News-Feed-Deadline-Status` is `cache_only` or `empty_timeout` when the pool step was cut short.
# NEWS_FEED_HANDLER_DEADLINE_MS="10000"

# Optional. Tail reserve (ms) after pool resolution for prune, facets, and JSON. Default 1500 (clamped 500–5000). Raise only if you see truncation or incomplete bodies; lowering steals time from RSS merge.
# NEWS_FEED_HANDLER_TAIL_RESERVE_MS="1500"

# Optional. Wall-clock budget (ms) for **starting** each RSS fetch on Vercel (cold miss + inline pool refresh). Default ~9000 (9s) when `VERCEL=1` and unset — leaves ~1s on a 10s Hobby runtime for dedupe/reconcile/JSON; fetches already in flight can still overrun. Set lower (e.g. 8000) if 504 persists; set 0/off/false to wait for all sources (dev or Pro/long maxDuration). Also set `VERCEL=1` locally to mimic production merge caps. Capped in practice by `NEWS_FEED_HANDLER_DEADLINE_MS` minus tail when the HTTP handler passes a deadline.
# NEWS_FEED_MERGE_WALL_MS="9000"

# Optional. Rolling window (hours) for the **no-list** merged pool only (`GET /api/news/feed` without `list`/`category`). Per-list pools use built-in defaults (e.g. headlines 24h, media 72h, stem 7d). Clamped 1–168; default 24.
# NEWS_FEED_RECENT_HOURS="24"

# Optional. Global override for merged pool L1/L2 TTL (seconds), clamped 3600–86400. When **unset**, TTL is derived from each pool’s `recentWindowHours` (list slug defaults in published-recent-window.ts) so cache horizon tracks the content window (still capped at 86400).
# NEWS_FEED_KV_TTL_SECONDS="86400"

# Optional. Min age (ms) of a cached pool before `GET /api/news/feed` with `offset=0` attempts an inline RSS reconcile (same as cron reconcile). Default 600000 (10m). Set to 0, off, or false to disable (serve L1/L2 only until TTL miss or external cron). On Vercel Hobby, prefer 0 + external cron so first-page requests avoid long merges.
# NEWS_FEED_POOL_REFRESH_MS="600000"

# Optional. When "1", `/news` overview prints structured browser console logs ([news:overview]). Dev always logs; prod: set this or localStorage news_debug=1.
# NEXT_PUBLIC_NEWS_CLIENT_LOG="1"

# Optional. Extra facet labels to drop from RSS categories/keywords (comma, semicolon, or newline separated). ASCII tokens are matched case-insensitively; CJK tokens are exact trim match. See services/news/facets/rss-facet-label-filter.ts defaults.
# RSS_FACET_DENYLIST_EXTRA="香港,台灣,Custom Desk"

# -----------------------------------------------------------------------------
# Cron / automation
# -----------------------------------------------------------------------------

# If set, cron routes require Authorization: Bearer <CRON_SECRET> or ?secret=<CRON_SECRET>.
# Use for scheduled jobs (e.g. GitHub Actions: sync movies-sync, tasi-sync).
# News merged pools (RSS → L1 + Upstash), e.g. every 10m from cron-job.org:
#   GET https://<host>/api/cron/sync/news-feed-pools?secret=<CRON_SECRET>
# Optional query: maxFeeds (default 15), region (cn|hk_tw), categories=comma-slugs, allPool=1 (also refresh API no-category pool).
# Vercel Hobby has a short function timeout; if the run exceeds it, use ?categories=general-news or fewer jobs, or raise the plan / maxDuration.
CRON_SECRET=""
