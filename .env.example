########################################
# Core storage & auth configuration
########################################

# GitHub Gist Id used for persistent JSON caches (holidays, fuel prices, movies, etc.).
# The service will read/write small JSON files (like movies.json) into this single Gist.
GIST_ID=""

# Personal access token with permission to read/write the Gist above.
# Do NOT use a token with unnecessary scopes.
GIST_TOKEN=""

# Basic auth credentials for the web UI and admin-only endpoints.
# Keep these secret and change them from the defaults in production.
#
# Admin Username
ACCESS_USERNAME="admin"
# Admin Password
ACCESS_PASSWORD="123456"

# Optional TOTP 2FA secret for admin login (Base32 string).
ACCESS_2FA_SECRET="xxxx"

# JWT configuration used by auth/session APIs.
#
# JWT Secret (random long string, at least 32 chars recommended).
JWT_SECRET=""

# JWT Token Expiration Time (e.g. 7d, 1h, 30m).
JWT_EXPIRES_IN="7d"

########################################
# Third-party API keys
########################################

# AMap (高德地图) API Key for geocoding / reverse-geocoding in the geo module.
AMAP_API_KEY=""

# Exchange Rate API Key (for freecurrencyapi or similar provider).
EXCHANGE_RATE_API_KEY=""

# TMDB API Key for the movies module (used by cron to merge Maoyan + TMDB data).
TMDB_API_KEY=""

# Optional TMDB language (default: zh-CN).
TMDB_LANGUAGE="zh-CN"

# Optional TMDB region filter, e.g. CN, US.
TMDB_REGION=""

########################################
# Cron / automation
########################################

# Optional secret for cron routes (e.g. /api/cron/sync/movies-gist).
# If set, requests must include:
#   - Authorization: Bearer $CRON_SECRET
#   or ?secret=$CRON_SECRET in the query string.
# Schedule via external cron (e.g. GitHub Actions) at e.g. UTC 04:00, 12:00, 20:00.
CRON_SECRET=""
