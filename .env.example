# -----------------------------------------------------------------------------
# Auth / JWT / Function Calling (OpenAI)
# -----------------------------------------------------------------------------

# Admin Username
ACCESS_USERNAME=""

# Admin Password
ACCESS_PASSWORD=""

# Optional. If set, login requires 2FA token verified by server-side logic.
ACCESS_2FA_SECRET=""

# JWT signing key for /api/auth/login tokens.
# If unset, the server falls back to ACCESS_PASSWORD or a built-in default.
JWT_SECRET=""

# JWT expiration time for generated tokens (e.g. 1d, 7d).
JWT_EXPIRES_IN="1d"

# OpenAI API key for POST /api/function-calling/chat
OPENAI_API_KEY=""

# Optional. (Legacy) Preferred YAML filename hint for clash rules in older setups.
# This option has no effect when using the KV-based proxy-rule clash cache.
# PROXY_RULE_CLASH_FILE="clash.unbnd.yaml"
# PROXY_RULE_CLASH_FILE="clash.vercel-proxy-rule.yaml"

# Optional. Raw HTTPS JSON URL for ZeroOmega backup (merged into public clash config).
# ZERO_OMEGA_RULES_JSON_URL=""

# Set to 1 to fetch gfwlist while NODE_ENV=development (otherwise skipped in dev).
# PROXY_RULE_FETCH_GFWLIST_IN_DEV="0"

# -----------------------------------------------------------------------------
# China GEO (reverse geocode, /api/geo, weather location)
# -----------------------------------------------------------------------------

# Supabase project for china_geo. Run sql/init-china-geo.sql once to create table + RPC; see sql/README.md.
CHINA_GEO_SUPABASE_URL=""
CHINA_GEO_SUPABASE_ANON_KEY=""
# Optional: service role key if RLS blocks anon read on china_geo.
# CHINA_GEO_SUPABASE_SERVICE_ROLE_KEY=""

# Turso (geo server cache L2 on Edge). Optional; when set, geo cache falls back to Turso after memory.
# Create DB at https://turso.tech ; then: Database URL and Auth Token.
# TURSO_DATABASE_URL="libsql://your-db-your-org.turso.io"
# TURSO_AUTH_TOKEN=""

# -----------------------------------------------------------------------------
# Weather (和风天气 QWeather)
# -----------------------------------------------------------------------------

# QWeather API Key (real-time + hourly forecast). https://dev.qweather.com
QWEATHER_API_KEY=""

# -----------------------------------------------------------------------------
# Exchange rate
# -----------------------------------------------------------------------------
# Optional: FreeCurrencyAPI.com API key (https://freecurrencyapi.com). When set, requests use it and avoid IP-based limits; when unset, fallback to ExchangeRate-API.com (no key, may be rate-limited by IP).
# FREECURRENCYAPI_API_KEY=""

# -----------------------------------------------------------------------------
# Movies (cron: 猫眼 Maoyan + TMDB merge → KV)
# -----------------------------------------------------------------------------
# 猫眼 (Maoyan): no API key; uses public apis.netstart.cn/maoyan (topRated, mostExpected).
# TMDB: requires TMDB_API_KEY for popular/upcoming and enrichment.

# --- TMDB (themoviedb.org) ---
TMDB_API_KEY=""
# Optional. Default zh-CN.
TMDB_LANGUAGE="zh-CN"
# Optional region filter, e.g. CN, US.
TMDB_REGION=""

# -----------------------------------------------------------------------------
# TASI (Saudi daily: cf-feed-bridge + Turso)
# -----------------------------------------------------------------------------
# Base URL of TASI feed for today's data. Required for /api/finance/tasi/* (today) and cron sync tasi-sync.
# Feed must expose: GET {url}/api/finance/tasi/company/daily → TasiCompanyDailyRecord[]
#                   GET {url}/api/finance/tasi/summary/daily → TasiMarketSummary
# TASI_FEED_URL="https://feed.davidjones.fun"

# SAHMK API key for hourly summary alignment endpoint /api/finance/tasi/summary/hourly
# and hourly cron ingest mode /api/cron/sync/finance-sync?mode=hourly
# Docs: https://www.sahmk.sa/en/developers/docs
# SAHMK_API_KEY="shmk_test_xxx_or_shmk_live_xxx"
# Optional override (default: https://app.sahmk.sa/api/v1)
# SAHMK_API_BASE_URL="https://app.sahmk.sa/api/v1"

# -----------------------------------------------------------------------------
# Debug (local only)
# -----------------------------------------------------------------------------

# Default: OFF — leave unset so caching works normally. Only for local debugging: set to 1, true, or yes in .env.local
# to disable app-layer caches and force Cache-Control: private, no-store on standard JSON.
# Never set in production unless you fully intend to (hurts performance and load).
# DISABLE_CACHE="1"

# Optional. Global MCP tool-call timeout (ms). Prevents slow tools from hitting platform first-byte limits by returning a tool error before hard timeout. Default 20000 (clamped 3000–24000).
# MCP_TOOL_CALL_TIMEOUT_MS="20000"

# -----------------------------------------------------------------------------
# Cron / automation
# -----------------------------------------------------------------------------

# If set, cron routes require Authorization: Bearer <CRON_SECRET> or ?secret=<CRON_SECRET>.
# Use for scheduled jobs (e.g. GitHub Actions: sync movies-sync, tasi-sync).
CRON_SECRET=""
